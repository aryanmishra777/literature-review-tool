# Copy this file to `.env` and fill in your own values. `.env` is gitignored.
#
# Ollama cloud API key. If set, the tool talks to Ollama cloud (https://ollama.com);
# if left blank, it falls back to a local Ollama at http://localhost:11434.
OLLAMA_API_KEY=your_key_here

# Groq API key. Required only when running with `--provider groq` (Groq is cloud-only,
# no local fallback). Get one at https://console.groq.com. Leave blank if unused.
GROQ_API_KEY=your_groq_key_here

# Contact address sent to the scholarly APIs (Crossref/OpenAlex `mailto`, Unpaywall
# `email`). Opts you into their faster "polite pool" and is required by Unpaywall.
# Optional but recommended; a placeholder is used if unset.
CONTACT_EMAIL=you@example.com
